SERVER_IP=127.0.0.1
SERVER_PORT=8080

JWT_SECRET=your_secret_key_here
JWT_EXPIRATION=86400  # 24 hours in seconds
DEFAULT_ADMIN_PASSWORD=admin

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:1420
CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE
CORS_ALLOW_HEADERS=Content-Type,Authorization

LOG_LEVEL=debug
DEVELOPMENT_MODE=true

# SQLite Database settings
DB_PATH=./data/lifelog.db

SURREALDB_URL=ws://localhost:8000
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NS=lifelog
SURREALDB_DB=data 

# Current server backend env vars (preferred; used by `lifelog-server-backend`)
LIFELOG_DB_ENDPOINT=127.0.0.1:7183
LIFELOG_DB_NAME=main
LIFELOG_DB_USER=root
LIFELOG_DB_PASS=root

# Optional transform configuration (JSON array). If unset, defaults to:
# [{"id":"ocr","enabled":true,"source_origin":"*:screen","language":"eng"}]
# source_origin uses DataOrigin format. Use "*:screen" for all devices.
# LIFELOG_TRANSFORMS_JSON=[{"id":"ocr","enabled":true,"source_origin":"*:screen","language":"eng"}]

# Preferred: one unified TOML config file for collector + server + transforms + aliases.
# If set, server reads [server] and transforms from this file.
# LIFELOG_CONFIG_PATH=/home/<user>/Projects/lifelog/lifelog-config.toml
